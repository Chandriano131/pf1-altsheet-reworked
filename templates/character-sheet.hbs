{{!--
  PF1E Alt Sheet Reworked — Template principal (FormApplication).
  Estrutura: <form> → header → nav.tabs → section.primary-body com divs por aba.
--}}

<form class="pf1ar-root sheet actor {{cssClass}}" data-tooltip-class="pf1" autocomplete="off">

  {{!-- ═══════════════════════════════════════════════════════════ HEADER ══ --}}
  <header class="pf1ar-header">
    <button type="button" class="pf1ar-theme-toggle" data-action="pf1arToggleTheme"
            data-tooltip="PF1AR.Labels.ToggleTheme" aria-label="{{localize "PF1AR.Labels.ToggleTheme"}}">
      <i class="fa-solid {{#if pf1arDark}}fa-sun{{else}}fa-moon{{/if}}" inert></i>
    </button>
    <button type="button" class="pf1ar-theme-cycle" data-action="pf1arCycleTheme"
            data-tooltip="PF1AR.Labels.CycleTheme" aria-label="{{localize "PF1AR.Labels.CycleTheme"}}">
      <i class="fa-solid fa-palette" inert></i>
    </button>
    <div class="pf1ar-portrait-wrap">
      <img class="pf1ar-portrait" src="{{actor.img}}" data-edit="img" alt="{{actor.name}}">
    </div>

    <div class="pf1ar-identity">
      <h1 class="pf1ar-name-row">
        <input class="pf1ar-charname" name="name" type="text" value="{{actor.name}}"
               placeholder="{{localize "PF1.CharacterName"}}">
      </h1>

      <div class="pf1ar-archetype-row">
        {{#each classes.0.items}}
          <span class="pf1ar-class-chip item" data-item-id="{{id}}">
            <img src="{{img}}" alt="">
            {{name}}
            {{#if level}}<b>{{level}}</b>{{/if}}
          </span>
        {{/each}}
      </div>

      <div class="pf1ar-bio-row">
        <label class="pf1ar-mini-field" data-tooltip="PF1.Gender">
          <i class="fa-solid fa-user" inert></i>
          <input type="text" name="system.details.gender" value="{{system.details.gender}}"
                 placeholder="{{localize "PF1.Gender"}}">
        </label>
        <label class="pf1ar-mini-field" data-tooltip="PF1.Deity">
          <i class="fa-solid fa-sun" inert></i>
          <input type="text" name="system.details.deity" value="{{system.details.deity}}"
                 placeholder="{{localize "PF1.Deity"}}">
        </label>
        <label class="pf1ar-mini-field pf1ar-mini-field-short" data-tooltip="PF1.Age">
          <i class="fa-solid fa-hourglass-half" inert></i>
          <input type="text" name="system.details.age" value="{{system.details.age}}"
                 placeholder="{{localize "PF1.Age"}}">
        </label>
        <label class="pf1ar-mini-field pf1ar-mini-field-short" data-tooltip="PF1.Height">
          <i class="fa-solid fa-ruler-vertical" inert></i>
          <input type="text" name="system.details.height" value="{{system.details.height}}"
                 placeholder="{{localize "PF1.Height"}}">
        </label>
        <label class="pf1ar-mini-field pf1ar-mini-field-short" data-tooltip="PF1.Weight">
          <i class="fa-solid fa-weight-scale" inert></i>
          <input type="text" name="system.details.weight" value="{{system.details.weight}}"
                 placeholder="{{localize "PF1.Weight"}}">
        </label>
        <div class="controls alignment pf1ar-alignment-control" data-tooltip="PF1.Alignment">
          <span class="pf1ar-alignment-badge">
            {{#if labels.alignment}}{{labels.alignment}}{{else}}{{localize "PF1.Alignment"}}{{/if}}
          </span>
          <a class="control alignment" data-tooltip="PF1.Alignment">
            <i class="fa-solid fa-pen-to-square" inert></i>
          </a>
        </div>
      </div>

      <div class="pf1ar-race-selector item"
           {{#if race}}data-item-id="{{race._id}}"{{/if}}
           data-tooltip="PF1.Race">
        <div class="item-image rollable pf1ar-race-image"
             {{#if race}}style='background-image: url("{{race.img}}")'{{/if}}
             data-tooltip="PF1.DisplayInChat">
          {{#unless race}}<i class="fa-solid fa-dna" inert></i>{{/unless}}
        </div>

        <div class="pf1ar-race-info">
          <span class="pf1ar-race-label">{{localize "PF1.Race"}}</span>
          {{#if race}}
            <h4>{{race.name}}</h4>
            <div class="tag-list">
              {{#each system.traits.creatureTypes.selected}}
                <span class="tag creature-type tag-id-{{cssId}}">{{label}}</span>
              {{/each}}
              {{#each system.traits.creatureSubtypes.selected}}
                <span class="tag creature-subtype tag-id-{{cssId}}">{{label}}</span>
              {{/each}}
            </div>
          {{else}}
            <span class="pf1ar-race-empty">{{localize "PF1AR.Labels.SelectRace"}}</span>
          {{/if}}
        </div>

        {{#if @root.owner}}
          <div class="item-controls pf1ar-race-controls">
            {{#if race}}
              <a class="item-control item-edit" data-tooltip="PF1.EditItem">
                <i class="fa-solid fa-edit" inert></i>
              </a>
              <a class="item-control item-delete" data-tooltip="PF1.DeleteItem">
                <i class="fa-solid fa-trash" inert></i>
              </a>
            {{else}}
              <a class="item-control item-create"
                 data-create="misc.race"
                 data-tooltip="PF1.CreateItem">
                <i class="fa-solid fa-plus" inert></i>
              </a>
              <a data-action="browse"
                 data-category="races"
                 data-tooltip="PF1.BrowseRaces">
                <i class="fa-solid fa-folder-plus" inert></i>
              </a>
            {{/if}}
          </div>
        {{/if}}
      </div>
    </div>

    <aside class="pf1ar-level-panel">
      <div class="pf1ar-level-heading">
        <span>{{localize "PF1.Level"}}</span>
        <strong>{{system.details.level.value}}</strong>
      </div>
      {{#if system.details.mythicTier}}
        <div class="pf1ar-tier">{{localize "PF1.Tier"}} {{system.details.mythicTier}}</div>
      {{/if}}
      {{#unless disableExperience}}
        <div class="pf1ar-xp">
          <span class="text-box direct allow-relative" name="system.details.xp.value" data-dtype="Number">{{system.details.xp.value}}</span>
          <span class="pf1ar-xp-sep">/</span>
          <span class="pf1ar-xp-max">{{system.details.xp.max}} XP</span>
        </div>
        <div class="pf1ar-xp-bar" aria-hidden="true">
          <span class="pf1ar-xp-fill" style="width: {{system.details.xp.pct}}%"></span>
        </div>
      {{/unless}}
    </aside>
  </header>

  {{!-- ═══════════════════════════════════════════════════════ TAB NAV ══ --}}
  <nav class="tabs pf1ar-primary-tabs" data-group="primary" aria-label="{{localize "PF1AR.SheetNavigation"}}">
    <a class="item active" data-tab="summary" data-group="primary"><i class="fa-solid fa-chart-simple" inert></i><span>{{localize "PF1.Summary"}}</span></a>
    <a class="item" data-tab="attributes" data-group="primary"><i class="fa-solid fa-dumbbell" inert></i><span>{{localize "PF1.Attributes"}}</span></a>
    <a class="item" data-tab="combat" data-group="primary"><i class="fa-solid fa-shield-halved" inert></i><span>{{localize "PF1.Combat"}}</span></a>
    <a class="item" data-tab="inventory" data-group="primary"><i class="fa-solid fa-box-open" inert></i><span>{{localize "PF1.Inventory"}}</span></a>
    <a class="item" data-tab="feats" data-group="primary"><i class="fa-solid fa-star" inert></i><span>{{localize "PF1.Features"}}</span></a>
    <a class="item" data-tab="skills" data-group="primary"><i class="fa-solid fa-list-check" inert></i><span>{{localize "PF1.Skills"}}</span></a>
    {{#if usesAnySpellbook}}
      <a class="item" data-tab="spellbook" data-group="primary"><i class="fa-solid fa-book-open" inert></i><span>{{localize "PF1.Spells"}}</span></a>
    {{/if}}
    <a class="item" data-tab="buffs" data-group="primary"><i class="fa-solid fa-wand-magic-sparkles" inert></i><span>{{localize "PF1.Buffs"}}</span></a>
    <a class="item" data-tab="biography" data-group="primary"><i class="fa-solid fa-scroll" inert></i><span>{{localize "PF1.Biography"}}</span></a>
    <a class="item" data-tab="notes" data-group="primary"><i class="fa-solid fa-note-sticky" inert></i><span>{{localize "PF1.Notes"}}</span></a>
    <a class="item" data-tab="settings" data-group="primary"><i class="fa-solid fa-gear" inert></i><span>{{localize "PF1.Settings"}}</span></a>
  </nav>

  {{!-- ══════════════════════════════════════════════════════ TAB BODY ══ --}}
  <section class="primary-body">

    <div class="tab flexcol" data-group="primary" data-tab="summary">
      {{> "modules/pf1-altsheet-reworked/templates/parts/summary.hbs"}}
    </div>

    <div class="tab flexcol" data-group="primary" data-tab="attributes">
      {{> "modules/pf1-altsheet-reworked/templates/parts/attributes.hbs"}}
    </div>

    <div class="tab flexcol" data-group="primary" data-tab="combat">
      {{> "modules/pf1-altsheet-reworked/templates/parts/combat.hbs"}}
    </div>

    <div class="tab flexcol" data-group="primary" data-tab="inventory">
      {{> "modules/pf1-altsheet-reworked/templates/parts/inventory.hbs"}}
    </div>

    <div class="tab flexcol" data-group="primary" data-tab="feats">
      {{> "modules/pf1-altsheet-reworked/templates/parts/features.hbs"}}
    </div>

    <div class="tab flexcol skills" data-group="primary" data-tab="skills">
      {{> "modules/pf1-altsheet-reworked/templates/parts/skills.hbs"}}
    </div>

    {{#if usesAnySpellbook}}
      <div class="tab flexcol" data-group="primary" data-tab="spellbook">
        {{> "modules/pf1-altsheet-reworked/templates/parts/spells.hbs"}}
      </div>
    {{/if}}

    <div class="tab flexcol" data-group="primary" data-tab="buffs">
      {{> "modules/pf1-altsheet-reworked/templates/parts/buffs.hbs"}}
    </div>

    <div class="tab flexcol" data-group="primary" data-tab="biography">
      {{editor biographyHTML target="system.details.biography.value" button=true editable=editable engine="prosemirror" collaborate=false}}
    </div>

    <div class="tab flexcol" data-group="primary" data-tab="notes">
      {{editor notesHTML target="system.details.notes.value" button=true editable=editable engine="prosemirror" collaborate=false}}
    </div>

    <div class="tab flexcol" data-group="primary" data-tab="settings">
      <div class="pf1ar-settings-shell">
        <h3 class="pf1ar-panel-title"><i class="fa-solid fa-gears" inert></i><span>{{localize "PF1.Settings"}}</span></h3>
        {{> "systems/pf1/templates/actors/parts/actor-settings.hbs"}}
      </div>
    </div>

  </section>

</form>
