{{!-- ABA: Buffs & Conditions --}}
<div class="pf1ar-tab-content pf1ar-buffs">

  {{!-- Condições --}}
  <h3 class="pf1ar-panel-title"><i class="fa-solid fa-heart-circle-exclamation" inert></i><span>{{localize "PF1AR.Sections.Conditions"}}</span></h3>
  <div class="pf1ar-conditions-grid">
    {{#each @root.conditions}}
    <div class="pf1ar-condition{{#if active}} active{{/if}}{{#if immune}} immune{{/if}}">
      <a class="pf1ar-condition-toggle checkbox" data-condition-id="{{id}}">
        <img src="{{img}}" width="32" height="32" alt="{{label}}">
        <span class="pf1ar-condition-name">{{label}}</span>
        {{#if racial}}
          <span class="pf1ar-condition-source">{{racial}}</span>
        {{else if inherited}}
          {{#each items}}
            <span class="pf1ar-condition-source">{{name}}</span>
          {{/each}}
        {{else if immune}}
          <span class="pf1ar-condition-source">{{localize "PF1.Immune"}}</span>
        {{/if}}
      </a>
      {{#if compendium}}
      <a class="pf1ar-condition-book" data-compendium-entry="{{compendium}}">
        <i class="fa-solid fa-book" inert></i>
      </a>
      {{/if}}
    </div>
    {{/each}}
  </div>

  <hr class="pf1ar-divider">

  {{!-- Filtro de buffs --}}
  <h3 class="pf1ar-panel-title"><i class="fa-solid fa-wand-magic-sparkles" inert></i><span>{{localize "PF1.Buffs"}}</span></h3>
  {{> "systems/pf1/templates/actors/parts/actor-item-nav-filters.hbs" category="buffs" sections=buffs}}

  {{!-- Lista de buffs --}}
  <section class="buffs-body">
    <ol class="item-groups-list" data-type="buff">
    {{#each buffs as |section sid|}}
    {{#unless section._hidden}}
      <ol class="item-list" data-list="{{section.id}}" data-type="{{section.create.type}}" data-subtype="{{section.create.system.subType}}">
        <li class="item-list-header flexrow pf1ar-item-list-header">
          <div class="item-name"><h3>{{pf1ar_localize section.label}}</h3></div>
          <div class="item-detail item-duration"><span>{{localize "PF1.Duration"}}</span></div>
          <div class="item-detail item-level"><span>{{localize "PF1.Level"}}</span></div>
          {{#if section.interface.actions}}
          <div class="item-detail item-actions"><i class="icon-pf icon-gears" data-tooltip="PF1.ActionPlural"></i></div>
          {{/if}}
          <div class="item-detail item-uses"><i class="icon-pf icon-battery-pack" data-tooltip="PF1.ChargePlural"></i></div>
          <div class="item-detail item-active"><span>{{localize "PF1.Active"}}</span></div>
          {{#if @root.owner}}
          <div class="item-controls">
            <a class="item-control item-create" data-tooltip="PF1.CreateItem" data-create="{{section.path}}">
              <i class="fa-solid fa-plus" inert></i>
            </a>
            <a data-action="browse" data-source="{{section.path}}" data-tooltip="PF1.BrowseBuffs">
              <i class="fa-solid fa-folder-plus" inert></i>
            </a>
          </div>
          {{/if}}
        </li>

        {{#each section.items as |item iid|}}
        <li class="item flexrow pf1ar-item-row" data-item-id="{{item.id}}">
          <div class="item-name rollable">
            <div class="item-image" style='background-image: url("{{item.img}}")' data-tooltip="PF1.DisplayInChat"></div>
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-detail item-duration">
            <span>{{#if item.labels.duration}}{{item.labels.duration}}{{/if}}</span>
          </div>
          <div class="item-detail item-level">
            <span class="text-box allow-relative" data-dtype="Number">{{#if item.level}}{{item.level}}{{/if}}</span>
          </div>
          {{#if section.interface.actions}}
          <div class="item-detail item-actions">
            {{#if item.hasAction}}
            <a class="item-control item-action action roll" data-tooltip="PF1.UseBuff">
              <i class="fa-solid fa-dice-d20" inert></i>
            </a>
            {{/if}}
          </div>
          {{/if}}
          <div class="item-detail item-uses flexrow" data-tooltip-extended="item.{{item.id}}.resources">
            {{#if item.isCharged}}
            <span class="text-box value allow-relative" data-wheel-step="1" data-dtype="Number">{{item.uses.value}}</span>
              {{#unless item.noMaxCharges}}
              <span class="sep"> / </span>
              <span class="max">{{item.uses.max}}</span>
              {{/unless}}
            {{/if}}
          </div>
          <div class="item-detail item-active">
            <input type="checkbox" {{checked item.active}}>
          </div>
          {{#if @root.owner}}
          <div class="item-controls">
            <a class="item-control item-edit" data-tooltip="PF1.EditItem"><i class="fa-solid fa-edit" inert></i></a>
            <a class="item-control item-duplicate" data-tooltip="PF1.DuplicateItem"><i class="fa-solid fa-copy" inert></i></a>
            <a class="item-control item-delete" data-tooltip="PF1.DeleteItem"><i class="fa-solid fa-trash" inert></i></a>
          </div>
          {{/if}}
        </li>
        {{/each}}
      </ol>
    {{/unless}}
    {{/each}}
    </ol>
  </section>

</div>
