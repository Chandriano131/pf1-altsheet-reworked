{{!-- ABA: Combat --}}
<div class="pf1ar-tab-content pf1ar-combat">

  {{!-- Cabeçalho de combate: BAB, CMB, Melee, Ranged, Initiative --}}
  <h3 class="pf1ar-panel-title"><i class="fa-solid fa-crosshairs" inert></i><span>{{localize "PF1AR.Sections.CombatStats"}}</span></h3>
  <div class="pf1ar-combat-header">
    <div class="pf1ar-stat-row">
      <div class="pf1ar-stat-box pf1ar-rollable" data-action="rollBAB" data-tooltip-extended="bab">
        <span class="pf1ar-stat-label">{{localize "PF1.BABAbbr"}}</span>
        <span class="pf1ar-stat-value">{{pf1ar_signedNum system.attributes.bab.total}}</span>
      </div>
      <div class="pf1ar-stat-box pf1ar-rollable" data-action="rollCMB" data-tooltip-extended="cmb">
        <span class="pf1ar-stat-label">{{localize "PF1.CMBAbbr"}}</span>
        <span class="pf1ar-stat-value">{{pf1ar_signedNum system.attributes.cmb.total}}</span>
      </div>
      <div class="pf1ar-stat-box pf1ar-rollable" data-action="rollGenericAttack" data-ranged="false" data-tooltip-extended="generic.attack.melee">
        <span class="pf1ar-stat-label">{{localize "PF1.Melee"}}</span>
        <span class="pf1ar-stat-value">{{pf1ar_signedNum genericAttacks.melee.modifier}}</span>
      </div>
      <div class="pf1ar-stat-box pf1ar-rollable" data-action="rollGenericAttack" data-ranged="true" data-tooltip-extended="generic.attack.ranged">
        <span class="pf1ar-stat-label">{{localize "PF1.Ranged"}}</span>
        <span class="pf1ar-stat-value">{{pf1ar_signedNum genericAttacks.ranged.modifier}}</span>
      </div>
      <div class="pf1ar-stat-box pf1ar-rollable" data-action="rollInit" data-tooltip-extended="init">
        <span class="pf1ar-stat-label">{{localize "PF1.Initiative"}}</span>
        <span class="pf1ar-stat-value">{{pf1ar_signedNum system.attributes.init.total}}</span>
      </div>
    </div>
  </div>

  {{!-- Filtro e lista de ataques --}}
  <h3 class="pf1ar-panel-title pf1ar-title-spaced"><i class="fa-solid fa-bullseye" inert></i><span>{{localize "PF1.Attacks"}}</span></h3>
  {{> "systems/pf1/templates/actors/parts/actor-item-nav-filters.hbs" category="attacks" sections=attacks}}

  <section class="attacks-body">
    <ol class="item-groups-list">
    {{#each attacks as |section sid|}}
    {{#unless section._hidden}}
      <ol class="item-list" data-list="{{section.id}}" data-type="{{section.create.type}}" data-subtype="{{section.create.system.subType}}">
        <li class="item-list-header flexrow pf1ar-item-list-header">
          <div class="item-name"><h3>{{pf1ar_localize section.label}}</h3></div>
          <div class="item-detail item-attacks"><label>{{localize "PF1.Attacks"}}</label></div>
          <div class="item-detail item-damage"><label>{{localize "PF1.Damage"}}</label></div>
          <div class="item-detail item-range"><label>{{localize "PF1.Range"}}</label></div>
          <div class="item-detail item-actions"><i class="icon-pf icon-gears" data-tooltip="PF1.ActionPlural"></i></div>
          <div class="item-detail item-uses"><i class="icon-pf icon-battery-pack" data-tooltip="PF1.ChargePlural"></i></div>
          {{#if @root.owner}}
          <div class="item-controls">
            {{#if section.interface.create}}
            <a class="item-control item-create" data-tooltip="PF1.CreateItem" data-create="{{section.path}}">
              <i class="fa-solid fa-plus" inert></i>
            </a>
            {{/if}}
          </div>
          {{/if}}
        </li>

        {{#each section.items as |item iid|}}
        <li class="item flexrow pf1ar-item-row" data-item-id="{{item.id}}">
          <div class="item-name rollable">
            <div class="item-image" style='background-image: url("{{item.img}}")' data-tooltip="PF1.DisplayInChat"></div>
            <h4>{{item.name}}</h4>
          </div>
          <div class="item-detail item-attacks" data-tooltip-extended="item.{{item.id}}.attacks">
            {{#if item.hasAttack}}<label>{{attackSummary}}</label>{{/if}}
          </div>
          <div class="item-detail item-damage" data-tooltip-extended="item.{{item.id}}.damage">
            {{#if item.hasDamage}}<label class="resolved-formula">{{actionDamage item.document.defaultAction}}</label>{{/if}}
          </div>
          <div class="item-detail item-range" data-tooltip-extended="item.{{item.id}}.range">
            {{#if item.hasRange}}<label>{{actionRange item.document.defaultAction null}}</label>{{/if}}
          </div>
          <div class="item-detail item-actions">
            {{#if item.hasAction}}
            <a class="item-control item-action action roll" data-tooltip="PF1.PerformAttack">
              <i class="fa-solid fa-dice-d20" inert></i>
            </a>
            {{/if}}
          </div>
          <div class="item-detail item-uses flexrow" data-tooltip-extended="item.{{item.id}}.resources">
            {{#if item.isCharged}}
            <span class="text-box value allow-relative" data-wheel-step="1" data-dtype="Number">{{item.charges}}</span>
              {{#unless item.noMaxCharges}}
              <span class="sep"> / </span>
              <span class="max">{{item.maxCharges}}</span>
              {{/unless}}
            {{else if item.usesAmmo}}
            <span class="ammo-remaining">{{item.ammoRemaining}}</span>
            {{/if}}
          </div>
          {{#if @root.owner}}
          <div class="item-controls">
            <a class="item-control item-edit" data-tooltip="PF1.EditItem"><i class="fa-solid fa-edit" inert></i></a>
            <a class="item-control item-delete" data-tooltip="PF1.DeleteItem"><i class="fa-solid fa-trash" inert></i></a>
          </div>
          {{/if}}
        </li>
        {{/each}}
      </ol>
    {{/unless}}
    {{/each}}
    </ol>
  </section>

  <hr class="pf1ar-divider">

  {{!-- Defesas --}}
  <div class="pf1ar-combat-defenses">
    <div class="pf1ar-defense-header">
      <h3 class="pf1ar-panel-title"><i class="fa-solid fa-shield-halved" inert></i><span>{{localize "PF1.Defenses"}}</span></h3>
      <div class="pf1ar-natural-armor">
        <label>{{localize "PF1.BuffTarACNatural"}}</label>
        <input name="system.attributes.naturalAC" type="number" value="{{system.attributes.naturalAC}}" placeholder="0" min="0" step="1">
      </div>
      <div class="pf1ar-sr-input">
        <label>{{localize "PF1.SpellResistance"}}</label>
        <input class="formula" name="system.attributes.sr.formula" type="text"
          placeholder="{{localize "PF1.Formula"}}"
          value="{{#if system.attributes.sr.formula}}{{system.attributes.sr.formula}}{{/if}}">
      </div>
    </div>

    {{> "systems/pf1/templates/actors/parts/actor-defenses_tables.hbs"}}

    {{!-- Notas de defesa --}}
    <div class="pf1ar-defense-notes">
      <div class="pf1ar-notes-row">
        <label>{{localize "PF1.SaveNotes"}}</label>
        <textarea name="system.attributes.saveNotes" placeholder="{{localize "PF1.SaveNotes"}}">{{system.attributes.saveNotes}}</textarea>
      </div>
      <div class="pf1ar-notes-row">
        <label>{{localize "PF1.ACNotes"}}</label>
        <textarea name="system.attributes.acNotes" placeholder="{{localize "PF1.ACNotes"}}">{{system.attributes.acNotes}}</textarea>
      </div>
      <div class="pf1ar-notes-row">
        <label>{{localize "PF1.CMDNotes"}}</label>
        <textarea name="system.attributes.cmdNotes" placeholder="{{localize "PF1.CMDNotes"}}">{{system.attributes.cmdNotes}}</textarea>
      </div>
      <div class="pf1ar-notes-row">
        <label>{{localize "PF1.SpellResistanceNotes"}}</label>
        <textarea name="system.attributes.srNotes" placeholder="{{localize "PF1.SpellResistanceNotes"}}">{{system.attributes.srNotes}}</textarea>
      </div>
    </div>
  </div>

</div>
