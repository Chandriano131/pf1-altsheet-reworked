{{!-- ABA: Features (Feats / Class Features / etc.) --}}
<div class="pf1ar-tab-content pf1ar-features">

  <h3 class="pf1ar-panel-title"><i class="fa-solid fa-star" inert></i><span>{{localize "PF1.Features"}}</span></h3>
  {{> "systems/pf1/templates/actors/parts/actor-item-nav-filters.hbs" category="features" sections=features}}

  <section class="feats-body">
    <ol class="item-groups-list">
    {{#each features as |section sid|}}
    {{#unless section._hidden}}
      <ol class="item-list" data-list="{{section.id}}" data-type="{{section.create.type}}" data-subtype="{{section.create.system.subType}}">
        <li class="item-list-header flexrow pf1ar-item-list-header">
          <div class="item-name"><h3>{{pf1ar_localize section.label}}</h3></div>
          {{#if section.interface.types}}<div class="item-detail item-type"><i class="icon-pf icon-magic-palm" data-tooltip="PF1.Type"></i></div>{{/if}}
          {{#if section.interface.actions}}
            <div class="item-detail item-actions"><i class="icon-pf icon-gears" data-tooltip="PF1.ActionPlural"></i></div>
            <div class="item-detail item-uses"><i class="icon-pf icon-battery-pack" data-tooltip="PF1.ChargePlural"></i></div>
            <div class="item-detail item-usage"><i class="icon-pf icon-hand" data-tooltip="PF1.Usage"></i></div>
          {{/if}}
          {{#if section.interface.level}}<div class="item-detail item-feat-level"><i class="icon-pf icon-upgrade" data-tooltip="PF1.Level"></i></div>{{/if}}
          {{#if @root.owner}}
          <div class="item-controls">
            {{#if section.interface.create}}
            <a class="item-control item-create" data-tooltip="PF1.CreateItem" data-create="{{section.path}}">
              <i class="fa-solid fa-plus" inert></i>
            </a>
            {{/if}}
            <a data-action="browse" data-source="{{section.path}}" data-tooltip="PF1.BrowseFeats">
              <i class="fa-solid fa-folder-plus" inert></i>
            </a>
          </div>
          {{/if}}
        </li>

        {{#each section.items as |item iid|}}
        <li class="item flexrow pf1ar-item-row{{#if item.disabled}} disabled{{/if}}{{#if item.pf1arIsLinkChild}} pf1ar-link-child{{/if}}"
            {{#if item.pf1arLinkDepth}}style="--pf1ar-link-depth: {{item.pf1arLinkDepth}}"{{/if}}
            data-item-id="{{item.id}}">
          <div class="item-name rollable">
            <div class="item-image" style='background-image: url("{{item.img}}")' data-tooltip="PF1.DisplayInChat"></div>
            <h4>{{item.name}}</h4>
          </div>
          {{#if section.interface.types}}
          <div class="item-detail item-type"><span>{{item.typelabel}}</span></div>
          {{/if}}
          {{#if section.interface.actions}}
          <div class="item-detail item-actions">
            {{#unless item.disabled}}
            {{#if item.hasAction}}
            <a class="item-control item-action action roll" data-tooltip="PF1.UseFeat">
              <i class="fa-solid fa-dice-d20" inert></i>
            </a>
            {{/if}}
            {{/unless}}
          </div>
          <div class="item-detail item-uses flexrow" data-tooltip-extended="item.{{item.id}}.resources">
            {{#if item.isCharged}}
            <span class="text-box value allow-relative" data-wheel-step="1" data-dtype="Number">{{item.uses.value}}</span>
              {{#unless item.noMaxCharges}}
              <span class="sep"> / </span>
              <span class="max">{{item.uses.max}}</span>
              {{/unless}}
            {{/if}}
          </div>
          <div class="item-detail item-usage">
            {{#if item.labels.activation}}<span>{{item.labels.activation}}</span>{{/if}}
          </div>
          {{/if}}
          {{#if section.interface.level}}
          <div class="item-detail item-feat-level" data-tooltip-extended="item.{{item.id}}.level">
            <span>{{item.level}}</span>
          </div>
          {{/if}}
          {{#if @root.owner}}
          <div class="item-controls">
            <a class="item-control item-edit" data-tooltip="PF1.EditItem"><i class="fa-solid fa-edit" inert></i></a>
            <a class="item-control item-delete" data-tooltip="PF1.DeleteItem"><i class="fa-solid fa-trash" inert></i></a>
          </div>
          {{/if}}
        </li>
        {{/each}}
      </ol>
    {{/unless}}
    {{/each}}
    </ol>
  </section>

  <footer class="pf1ar-feat-footer" data-tooltip-extended="feats" data-tooltip-direction="UP">
    <div class="pf1ar-feat-formula">
      <label>{{localize "PF1.BonusFeatFormula"}}</label>
      <input class="formula" type="text" name="system.details.bonusFeatFormula"
             value="{{system.details.bonusFeatFormula}}" placeholder="{{localize "PF1.Formula"}}">
    </div>
    <div class="pf1ar-feat-counts">
      <div class="pf1ar-feat-count"><span>{{localize "PF1.Feats"}}</span><strong>{{featCount.active}}</strong></div>
      <div class="pf1ar-feat-count"><span>{{localize "PF1.ByLevel"}}</span><strong>{{featCount.levels}}</strong></div>
      <div class="pf1ar-feat-count"><span>{{localize "PF1.ByBonus"}}</span><strong>{{featCount.bonus}}</strong></div>
      <div class="pf1ar-feat-count"><span>{{localize "PF1.Total"}}</span><strong>{{featCount.max}}</strong></div>
    </div>
  </footer>

</div>
