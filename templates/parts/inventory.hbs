{{!-- ABA: Inventory --}}
<div class="pf1ar-tab-content pf1ar-inventory">

  {{!-- Moeda --}}
  <h3 class="pf1ar-panel-title"><i class="fa-solid fa-coins" inert></i><span>{{localize "PF1.Currency.Label"}}</span></h3>
  <div class="pf1ar-currency-section">
    <div class="pf1ar-currency-row">
      <h4 class="pf1ar-currency-title">{{localize "PF1.Currency.Label"}}</h4>
      {{#each system.currency as |v k|}}
        <div class="pf1ar-currency">
          <label class="pf1ar-currency-label">{{lookup @root.config.currencies k}}</label>
          <span class="text-box direct allow-relative" name="system.currency.{{k}}">{{v}}</span>
        </div>
      {{/each}}
    </div>
    {{#if isCharacter}}
    <div class="pf1ar-currency-row">
      <h4 class="pf1ar-currency-title">{{localize "PF1.Currency.Weightless"}}</h4>
      {{#each system.altCurrency as |v k|}}
        <div class="pf1ar-currency">
          <label class="pf1ar-currency-label">{{lookup @root.config.currencies k}}</label>
          <span class="text-box direct allow-relative" name="system.altCurrency.{{k}}">{{v}}</span>
        </div>
      {{/each}}
    </div>
    {{/if}}
  </div>

  {{!-- Filtro de inventário --}}
  <h3 class="pf1ar-panel-title pf1ar-title-spaced"><i class="fa-solid fa-box-open" inert></i><span>{{localize "PF1.Inventory"}}</span></h3>
  {{> "systems/pf1/templates/actors/parts/actor-item-nav-filters.hbs" category="inventory" sections=inventory}}

  {{!-- Lista de itens --}}
  <section class="inventory-body">
  {{#each inventory as |section sid|}}
  {{#unless section._hidden}}
    <ol class="item-list pf1ar-inventory-list{{#unless @root.owner}} pf1ar-readonly-list{{/unless}}"
        data-list="{{section.id}}"
        data-type="{{section.create.type}}"
        data-subtype="{{section.create.system.subType}}">
      <li class="item-list-header flexrow pf1ar-item-list-header">
        <div class="item-name"><h3>{{pf1ar_localize section.label}}</h3></div>
        <div class="item-detail item-actions{{#unless section.interface.actions}} pf1ar-column-placeholder{{/unless}}"><i class="icon-pf icon-gears" data-tooltip="PF1.ActionPlural"></i></div>
        <div class="item-detail item-value{{#unless section.interface.value}} pf1ar-column-placeholder{{/unless}}"><i class="icon-pf icon-coins" data-tooltip="PF1.Value"></i></div>
        <div class="item-detail item-weight"><i class="icon-pf icon-weight" data-tooltip="PF1.ItemWeight"></i></div>
        <div class="item-detail item-carried"><i class="icon-pf icon-wheelbarrow" data-tooltip="PF1.Carried"></i></div>
        <div class="item-detail item-equipped{{#unless section.interface.equip}} pf1ar-column-placeholder{{/unless}}"><i class="icon-pf icon-battle-gear" data-tooltip="PF1.Equipped"></i></div>
        <div class="item-detail item-uses"><i class="icon-pf icon-battery-pack" data-tooltip="PF1.ChargePlural"></i></div>
        {{#if @root.owner}}
        <div class="item-controls">
          {{#if section.interface.create}}
          <a class="item-control item-create" data-tooltip="PF1.CreateItem" data-create="{{section.path}}">
            <i class="fa-solid fa-plus" inert></i>
          </a>
          {{/if}}
          <a data-action="browse" data-source="{{section.path}}" data-tooltip="PF1.BrowseItems">
            <i class="fa-solid fa-folder-plus" inert></i>
          </a>
        </div>
        {{/if}}
      </li>

      {{#each section.items as |item iid|}}
      <li class="item flexrow pf1ar-item-row{{#if item.pf1arIsContainer}} pf1ar-container-row{{/if}}{{#if item.disabled}} disabled{{/if}}{{#if item.isEmpty}} empty{{/if}}{{#if item.destroyed}} destroyed{{else if item.isBroken}} broken{{/if}}"
          data-item-id="{{item.id}}"
          {{#if item.pf1arIsContainer}}data-container-drop-id="{{item.id}}"{{/if}}>
        <div class="item-name">
          <div class="item-image rollable" style='background-image: url("{{item.img}}")' data-tooltip="PF1.DisplayInChat"></div>
          {{#if item.isStack}}
          <span class="quantity stack">{{item.quantity}}</span>
          {{else if item.isEmpty}}
          <span class="quantity empty">{{item.quantity}}</span>
          {{/if}}
          <h4>{{item.name}}</h4>
        </div>
        <div class="item-detail item-actions{{#unless section.interface.actions}} pf1ar-column-placeholder{{/unless}}">
          {{#if section.interface.actions}}
          {{#unless (or item.showUnidentifiedData item.disabled)}}
          {{#if item.hasAction}}
          <a class="item-control item-action action roll" data-tooltip="PF1.UseItem">
            <i class="fa-solid fa-dice-d20" inert></i>
          </a>
          {{/if}}
          {{/unless}}
          {{/if}}
        </div>
        <div class="item-detail item-value{{#unless section.interface.value}} pf1ar-column-placeholder{{/unless}}">
          {{#if section.interface.value}}
          <span>{{item.labels.price}}</span>
          {{/if}}
        </div>
        <div class="item-detail item-weight">
          {{#if item.isPhysical}}
          <span>{{numberFormatAlt item.weight.converted.total decimals=2}} {{@root.units.weight}}</span>
          {{/if}}
        </div>
        <div class="item-detail item-carried">
          <a class="item-control item-carry"><span>{{{item.labels.carried}}}</span></a>
        </div>
        <div class="item-detail item-equipped{{#unless section.interface.equip}} pf1ar-column-placeholder{{/unless}}">
          {{#if section.interface.equip}}
          <a class="item-control item-equip"><span>{{{item.labels.equipped}}}</span></a>
          {{/if}}
        </div>
        <div class="item-detail item-uses flexrow" data-tooltip-extended="item.{{item.id}}.resources">
          {{#unless item.showUnidentifiedData}}
          {{#if item.hasResource}}
          <span class="text-box value allow-relative" data-wheel-step="1" data-dtype="Number">{{item.uses.value}}</span>
            {{#unless item.noMaxCharges}}
            <span class="sep"> / </span>
            <span class="max">{{item.uses.max}}</span>
            {{/unless}}
          {{/if}}
          {{/unless}}
        </div>
        {{#if @root.owner}}
        <div class="item-controls">
          <a class="item-control item-quantity-add" data-tooltip="PF1.QuantityAdd"><i class="fa-solid fa-plus" inert></i></a>
          <a class="item-control item-quantity-subtract" data-tooltip="PF1.QuantitySub"><i class="fa-solid fa-minus" inert></i></a>
          <a class="item-control item-edit" data-tooltip="PF1.EditItem"><i class="fa-solid fa-edit" inert></i></a>
          <a class="item-control item-duplicate" data-tooltip="PF1.DuplicateItem"><i class="fa-solid fa-copy" inert></i></a>
          <a class="item-control item-split{{#unless item.isStack}} disabled{{/unless}}" data-tooltip="PF1.SplitItem"><i class="fa-solid fa-people-arrows" inert></i></a>
          <a class="item-control item-give" data-tooltip="PF1.GiveItem"><i class="fa-solid fa-gift" inert></i></a>
          <a class="item-control item-delete" data-tooltip="PF1.DeleteItem"><i class="fa-solid fa-trash" inert></i></a>
        </div>
        {{/if}}

        {{#if item.pf1arContents}}
        <details class="pf1ar-container-contents"
                 data-container-id="{{item.id}}"
                 data-container-drop-id="{{item.id}}"
                 {{#if item.pf1arContents.open}}open{{/if}}>
          <summary>
            <span class="pf1ar-container-contents-title">
              <i class="fa-solid fa-box-open" inert></i>
              <span>{{localize "PF1.Containers.Contents.Label"}}</span>
              <strong>{{item.pf1arContents.count}}</strong>
            </span>
            <span class="pf1ar-container-contents-meta">
              <span>{{localize "PF1.Weight"}}: <b>{{numberFormatAlt item.pf1arContents.weight decimals=2}} {{@root.units.weight}}</b></span>
              <span>{{localize "PF1.Value"}}: <b>{{item.pf1arContents.valueLabel}}</b></span>
              <span>{{localize "PF1.SellValue"}}: <b>{{item.pf1arContents.sellValueLabel}}</b></span>
              {{#if item.pf1arContents.hasCurrency}}
              <span>{{localize "PF1.Currency.Label"}}: <b>{{item.pf1arContents.currencyLabel}}</b></span>
              {{/if}}
            </span>
          </summary>

          {{#each item.pf1arContents.sections as |childSection csid|}}
          <ol class="pf1ar-contained-list{{#unless @root.owner}} pf1ar-readonly-list{{/unless}}{{#unless @root.isGM}} pf1ar-no-gm-column{{/unless}}"
              data-list="{{childSection.id}}">
            <li class="pf1ar-contained-header">
              <div class="pf1ar-contained-name"><h4>{{pf1ar_localize childSection.label}}</h4></div>
              <div class="pf1ar-contained-detail{{#unless childSection.interface.actions}} pf1ar-column-placeholder{{/unless}}"><i class="icon-pf icon-gears" data-tooltip="PF1.ActionPlural"></i></div>
              <div class="pf1ar-contained-detail{{#unless childSection.interface.value}} pf1ar-column-placeholder{{/unless}}"><i class="icon-pf icon-coins" data-tooltip="PF1.Value"></i></div>
              <div class="pf1ar-contained-detail"><i class="icon-pf icon-weight" data-tooltip="PF1.ItemWeight"></i></div>
              {{#if @root.isGM}}<div class="pf1ar-contained-detail"><i class="icon-pf icon-quill-ink" data-tooltip="PF1.Identified"></i></div>{{/if}}
              <div class="pf1ar-contained-detail"><i class="icon-pf icon-battery-pack" data-tooltip="PF1.ChargePlural"></i></div>
              {{#if @root.owner}}<div class="pf1ar-contained-controls"><i class="fa-solid fa-gear" inert></i></div>{{/if}}
            </li>

            {{#each childSection.items as |child cid|}}
            <li class="pf1ar-contained-row{{#if child.disabled}} disabled{{/if}}{{#if child.isEmpty}} empty{{/if}}{{#if child.destroyed}} destroyed{{else if child.isBroken}} broken{{/if}}"
                data-container-id="{{item.id}}"
                data-contained-item-id="{{child.id}}"
                draggable="true">
              <div class="pf1ar-contained-name">
                <a class="pf1ar-contained-image" style='background-image: url("{{child.img}}")' data-action="pf1arContainedCard" data-tooltip="PF1.DisplayInChat"></a>
                <span class="quantity{{#if child.isStack}} stack{{/if}}{{#if child.isEmpty}} empty{{else if (eq child.quantity 1)}} singular{{/if}}">{{child.quantity}}</span>
                <h4>{{child.name}}</h4>
              </div>

              <div class="pf1ar-contained-detail{{#unless childSection.interface.actions}} pf1ar-column-placeholder{{/unless}}">
                {{#if childSection.interface.actions}}
                {{#unless (or child.showUnidentifiedData child.disabled)}}
                {{#if child.hasAction}}
                <a class="pf1ar-contained-control" data-action="pf1arContainedAction" data-tooltip="PF1.UseItem">
                  <i class="fa-solid fa-dice-d20" inert></i>
                </a>
                {{/if}}
                {{/unless}}
                {{/if}}
              </div>

              <div class="pf1ar-contained-detail{{#unless childSection.interface.value}} pf1ar-column-placeholder{{/unless}}">
                {{#if childSection.interface.value}}
                {{#if child.price}}<span>{{localize @root.labels.currency value=child.price.stack}}</span>{{/if}}
                {{/if}}
              </div>

              <div class="pf1ar-contained-detail">
                {{#if child.isPhysical}}
                <span>{{numberFormatAlt child.weight.converted.total decimals=2}} {{@root.units.weight}}</span>
                {{/if}}
              </div>

              {{#if @root.isGM}}
              <div class="pf1ar-contained-detail">
                <a class="pf1ar-contained-control pf1ar-contained-identify" data-action="pf1arContainedIdentify" data-tooltip="PF1.Identified">
                  <span>{{{child.labels.identified}}}</span>
                </a>
              </div>
              {{/if}}

              <div class="pf1ar-contained-detail pf1ar-contained-uses" data-tooltip-extended="item.{{child.id}}.resources">
                {{#unless child.showUnidentifiedData}}
                {{#if child.hasResource}}
                <input type="text" class="pf1ar-contained-uses-input" data-wheel-step="1" value="{{child.uses.value}}" data-dtype="Number">
                  {{#unless child.noMaxCharges}}
                  <span class="sep"> / </span>
                  <span class="max">{{child.uses.max}}</span>
                  {{/unless}}
                {{/if}}
                {{/unless}}
              </div>

              {{#if @root.owner}}
              <div class="pf1ar-contained-controls">
                <a class="pf1ar-contained-control" data-action="pf1arContainedQuantity" data-delta="1" data-tooltip="PF1.QuantityAdd"><i class="fa-solid fa-plus" inert></i></a>
                <a class="pf1ar-contained-control" data-action="pf1arContainedQuantity" data-delta="-1" data-tooltip="PF1.QuantitySub"><i class="fa-solid fa-minus" inert></i></a>
                <a class="pf1ar-contained-control" data-action="pf1arContainedEdit" data-tooltip="PF1.EditItem"><i class="fa-solid fa-edit" inert></i></a>
                <a class="pf1ar-contained-control" data-action="pf1arContainedDuplicate" data-tooltip="PF1.DuplicateItem"><i class="fa-solid fa-copy" inert></i></a>
                <a class="pf1ar-contained-control" data-action="pf1arContainedTake" data-tooltip="PF1.Containers.Contents.Take"><i class="fa-solid fa-arrow-alt-circle-down" inert></i></a>
                <a class="pf1ar-contained-control danger" data-action="pf1arContainedDelete" data-tooltip="PF1.DeleteItem"><i class="fa-solid fa-trash" inert></i></a>
              </div>
              {{/if}}
            </li>
            {{/each}}
          </ol>
          {{/each}}
        </details>
        {{/if}}
      </li>
      {{/each}}
    </ol>
  {{/unless}}
  {{/each}}
  </section>

  {{#unless isLootSheet}}
    <footer class="pf1ar-carry-footer" data-tooltip-extended="carryCapacity" data-tooltip-direction="UP">
      <h3 class="pf1ar-panel-title"><i class="fa-solid fa-weight-hanging" inert></i><span>{{localize "PF1.Encumbrance"}}</span></h3>
      <div class="pf1ar-carry-bonus">
        <label>
          <span>{{localize "PF1.BonusCarryStrength"}}</span>
          <input name="system.details.carryCapacity.bonus.user" value="{{system.details.carryCapacity.bonus.user}}" type="number" placeholder="0" step="1">
        </label>
        <label>
          <span>{{localize "PF1.BonusCarryMultiplier"}}</span>
          <input name="system.details.carryCapacity.multiplier.user" value="{{system.details.carryCapacity.multiplier.user}}" type="number" placeholder="0">
        </label>
      </div>
      {{#with encumbrance}}
        <div class="pf1ar-carry-summary">
          <span class="tag">{{carryLabel}}</span>
          <span class="tag">{{@root.labels.totalValue}}</span>
        </div>
        <div class="pf1ar-carry-capacity">
          <div class="pf1ar-load-meter {{#if encumbered.light}}encumbered{{/if}}">
            {{#if pct.light}}<span class="pf1ar-load-fill" style="width:{{pct.light}}%"></span>{{/if}}
            <span class="pf1ar-load-label">{{localize "PF1.CarryLightLoad"}} <b>{{light}}</b></span>
          </div>
          <div class="pf1ar-load-meter {{#if encumbered.medium}}encumbered{{/if}}">
            {{#if pct.medium}}<span class="pf1ar-load-fill" style="width:{{pct.medium}}%"></span>{{/if}}
            <span class="pf1ar-load-label">{{localize "PF1.CarryMediumLoad"}} <b>{{medium}}</b></span>
          </div>
          <div class="pf1ar-load-meter {{#if encumbered.heavy}}encumbered{{/if}}">
            {{#if pct.heavy}}<span class="pf1ar-load-fill" style="width:{{pct.heavy}}%"></span>{{/if}}
            <span class="pf1ar-load-label">{{localize "PF1.CarryHeavyLoad"}} <b>{{heavy}}</b></span>
          </div>
        </div>
        <div class="pf1ar-lift-grid">
          <div class="pf1ar-lift-card"><span>{{localize "PF1.CarryAboveHead"}}</span><strong>{{aboveHead}}</strong></div>
          <div class="pf1ar-lift-card"><span>{{localize "PF1.CarryOffGround"}}</span><strong>{{offGround}}</strong></div>
          <div class="pf1ar-lift-card"><span>{{localize "PF1.CarryDragPush"}}</span><strong>{{dragPush}}</strong></div>
        </div>
      {{/with}}
    </footer>
  {{/unless}}

</div>
