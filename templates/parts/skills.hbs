{{!-- ABA: Skills — estrutura funcional do PF1E com apresentação do módulo --}}
<div class="pf1ar-tab-content pf1ar-skills-tab">
  <h3 class="pf1ar-panel-title"><i class="fa-solid fa-list-check" inert></i><span>{{localize "PF1.Skills"}}</span></h3>

  <header class="flexcol skill-ranks">
    <div class="form-group">
      <div class="flexrow skill-rank-formula">
        <label>{{localize "PF1.SkillBonusRankFormula"}}</label>
        <input class="formula" type="text" name="system.details.bonusSkillRankFormula"
               value="{{system.details.bonusSkillRankFormula}}" placeholder="{{localize "PF1.Formula"}}">
      </div>
      <a class="skill-lock-button{{#unless @root.skillsLocked}} unlocked{{/unless}}"
         data-tooltip="PF1.ToggleSkillLock"></a>
    </div>

    <div class="flexrow skill-ranks">
      <div class="info-box-joined adventure" data-tooltip-extended="skills.adventure">
        <div class="info-box available">
          <h5>{{localize "PF1.SkillRankPlural"}}</h5>
          <span class="value">{{skillRanks.allowed}}</span>
        </div>
        <div class="info-box used">
          <h5>{{localize "PF1.Used"}}</h5>
          <span class="value">{{skillRanks.used}}</span>
        </div>
      </div>

      {{#if useBGSkills}}
        <div class="info-box transferred">
          <h5>{{localize "PF1.Transferred"}}</h5>
          <span class="value">{{skillRanks.sentToBG}}</span>
        </div>

        <div class="info-box-joined background" data-tooltip-extended="skills.background">
          <div class="info-box available">
            <h5>{{localize "PF1.BGSkillRanks"}}</h5>
            <span class="value">{{skillRanks.bgAllowed}}</span>
          </div>
          <div class="info-box used">
            <h5>{{localize "PF1.BGUsed"}}</h5>
            <span class="value">{{skillRanks.bgUsed}}</span>
          </div>
        </div>
      {{/if}}

      <div class="info-box acp" data-tooltip-extended="acp">
        <h5>{{localize "PF1.ACP"}}</h5>
        <span class="value">{{system.attributes.acp.total}}</span>
      </div>
    </div>
  </header>

  {{#if useBGSkills}}
    <nav class="sheet-navigation tabs" data-group="skillset">
      <a class="item" data-tab="adventure" data-group="skillset">{{localize "PF1.SkillTypeAdventure"}}</a>
      <a class="item" data-tab="background" data-group="skillset">{{localize "PF1.SkillTypeBackground"}}</a>
    </nav>

    <section class="skillset-body">
      <div class="tab" data-group="skillset" data-tab="adventure">
        {{> "modules/pf1-altsheet-reworked/templates/parts/skill-list.hbs"
            skillset=skillsets.adventure.skills isBackgroundSkills="false" skillGroup="adventure"}}
      </div>
      <div class="tab" data-group="skillset" data-tab="background">
        {{> "modules/pf1-altsheet-reworked/templates/parts/skill-list.hbs"
            skillset=skillsets.background.skills isBackgroundSkills="true" skillGroup="background"}}
      </div>
    </section>
  {{else}}
    <section class="skillset-body">
      <div class="tab active" data-group="skillset" data-tab="all">
        {{> "modules/pf1-altsheet-reworked/templates/parts/skill-list.hbs"
            skillset=skillsets.all.skills isBackgroundSkills="false" skillGroup="adventure"}}
      </div>
    </section>
  {{/if}}
</div>
